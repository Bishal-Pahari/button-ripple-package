# Supply-chain hardening — see SECURITY.md

# Block dependency lifecycle scripts (postinstall/preinstall/install). This is
# the payload-delivery path used by the 2025 npm worm attacks (e.g. Shai-Hulud).
# Explicitly-invoked `npm run build` still runs; publishing goes through the CI
# workflow, which builds before `npm publish`. After cloning, run a manual
# `npm run build` before any local publish since `prepublishOnly` is skipped.
ignore-scripts=true

# Add new dependencies pinned to an exact version (no floating ranges).
save-exact=true

# Surface known-vulnerable dependencies on install.
audit=true
